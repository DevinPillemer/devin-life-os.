# Floopify v2 — Environment Variables
# Copy this file to .env.local and fill in your values

# ── Strava API ──
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# ── Notion API ──
NOTION_API_KEY=
NOTION_GOALS_DB_ID=
NOTION_LEARNING_DB_ID=

# ── Google Sheets (Finance + Wallet) ──
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Google Calendar ──
GOOGLE_CALENDAR_ID=

# ── Habitify ──
HABITIFY_API_KEY=

# ── Apple Health Webhook ──
APPLE_HEALTH_WEBHOOK_SECRET=

# ── App URL ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
